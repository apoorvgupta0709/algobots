# Copy to .env and fill in. NEVER commit .env.

# --- Fyers API (https://myapi.fyers.in) ---
client_id=XXXXXXXX-100        # app id
secret_key=YYYYYYYYYY
redirect_uri=https://127.0.0.1
response_type=code
grant_type=authorization_code

# --- Fyers headless TOTP login ---
FY_ID=XX00000                 # Fyers login id
APP_ID_TYPE=2                 # 2 = web login
TOTP_KEY=BASE32TOTPSECRET     # from Fyers 2FA setup
PIN=0000                      # 4-digit trading pin

# --- Infra ---
# REQUIRED: docker compose refuses to start without it. Use a long random
# value; the old default "algobot" is a well-known weak credential.
POSTGRES_PASSWORD=
# DATABASE_URL=postgresql+psycopg2://algobot:<password>@localhost:5432/algobot   # outside docker

# --- API auth ---
# REQUIRED for control endpoints (promote/demote/killswitch/gates, POST
# /queries). Long random string; sent as the X-API-Key header. When unset,
# state-changing routes return 503 (fail closed); reads stay available.
ALGOBOT_API_KEY=

# --- Live-order fuse ---
# Leave unset/false. Overrides config/settings.yaml live_orders_enabled.
# Setting this to true is the explicit act of enabling REAL order routing.
# ALGOBOT_LIVE_ORDERS_ENABLED=false

# --- Telegram alerts (optional dead-man's switch) ---
# When both are set, the cron tick wrappers push an alert on failure / stale
# heartbeat via scripts/notify_telegram.sh. Leave empty to disable (silent).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
